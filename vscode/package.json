{
  "name": "android-studio-bridge-vscode",
  "displayName": "Android Studio Bridge",
  "description": "Quietly open HTML source-link nodes in Android Studio at the requested line and column.",
  "version": "0.1.2",
  "publisher": "learner-geek-perfectionist",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:asBridge.restart",
    "onCommand:asBridge.showStatus"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "asBridge.restart",
        "title": "Android Studio Bridge: Restart Server"
      },
      {
        "command": "asBridge.showStatus",
        "title": "Android Studio Bridge: Show Status"
      }
    ],
    "configuration": {
      "title": "Android Studio Bridge",
      "properties": {
        "asBridge.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Source root used to resolve relative paths from HTML links. Empty means the first VS Code workspace folder."
        },
        "asBridge.androidStudioExecutable": {
          "type": "string",
          "default": "studio",
          "description": "Android Studio launcher or executable path used to open files."
        },
        "asBridge.port": {
          "type": "number",
          "default": 17321,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Local bridge port. The server listens on 127.0.0.1 only."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/**/*.test.js",
    "package": "mkdir -p ../dist && vsce package --allow-missing-repository --out ../dist/android-studio-bridge-vscode-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.5.3"
  }
}
